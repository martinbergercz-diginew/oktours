# Copy to .env and fill in. Never commit .env.
# In production these are baked into the systemd unit.

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Repo / deploy paths.
# In local dev, LEAVE THESE COMMENTED — server.js auto-detects:
#   REPO_PATH = the monorepo root (three levels up from src/)
#   STAGING_PATH, SHADOW_PATH, LIVE_PATH, PREVIOUS_PATH = ./data/dev-*/
# In production, /etc/oktours-admin.env (managed by systemd) sets these
# explicitly to /srv/oktours-repo and /var/www/oktours-*. This file is
# for local dev only.
#
# REPO_PATH=/srv/oktours-repo
# STAGING_PATH=/var/www/oktours-staging
# SHADOW_PATH=/var/www/oktours-shadow
# LIVE_PATH=/var/www/oktours
# PREVIOUS_PATH=/var/www/oktours-previous

# Public URLs surfaced to the client
STAGING_URL=https://oktours-staging.diginew.cz
LIVE_URL=https://oktours.cz

# Notifications
NOTIFY_EMAIL=martinbergercz@gmail.com
SMTP_HOST=localhost
SMTP_PORT=25

# Shared secret for POST /admin/api/redeploy-main (Martin's claude.ai flow).
# Generate with: openssl rand -hex 32
REDEPLOY_TOKEN=

# Local-dev mode skips git push, rsync, email. Set to true ONLY in dev.
DRY_RUN=true
